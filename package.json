{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "postinstall": "tsx script/patch-node-cron-sourcemaps.ts",
    "dev": "cross-env NODE_ENV=development tsx server/index.ts",
    "build": "tsx script/build.ts",
    "start:orig": "NODE_ENV=production node dist/index.cjs",
    "start": "cross-env NODE_ENV=production node --env-file=.env.prod dist/index.cjs",
    "check": "npm run check:encoding && npm run check:destructive-inventory && tsc && npm run lint:encoding",
    "typecheck": "tsc --noEmit",
    "lint": "eslint client/src server shared --ext .ts,.tsx",
    "audit:local": "node scripts/run-local-audit.mjs",
    "analyze:boundaries": "eslint client/src server shared tests --ext .ts,.tsx --rule \"@typescript-eslint/no-unused-vars: off\" --rule \"@typescript-eslint/no-floating-promises: off\" --rule \"@typescript-eslint/no-misused-promises: off\" --rule \"@typescript-eslint/no-explicit-any: off\"",
    "analyze:arch": "depcruise --config .dependency-cruiser.cjs --output-type err client/src server shared tests",
    "analyze:arch:graph": "node scripts/prepare-analysis-output.mjs && depcruise --config .dependency-cruiser.cjs --include-only \"^(client/src|server|shared|tests)\" --output-type err-html --output-to .tmp-analysis/dependency-graph.html client/src server shared tests",
    "analyze:coverage": "npm run test:coverage",
    "analyze:knip": "cross-env MYSQL_DATABASE_URL=mysql://analysis:analysis@127.0.0.1:3306/mugplan_analysis knip --config knip.config.ts --reporter compact --no-progress --no-exit-code",
    "analyze:knip:deps": "cross-env MYSQL_DATABASE_URL=mysql://analysis:analysis@127.0.0.1:3306/mugplan_analysis knip --config knip.config.ts --dependencies --reporter compact --no-progress --no-exit-code",
    "analyze:knip:exports": "cross-env MYSQL_DATABASE_URL=mysql://analysis:analysis@127.0.0.1:3306/mugplan_analysis knip --config knip.config.ts --exports --reporter compact --no-progress --no-exit-code",
    "analyze:knip:files": "cross-env MYSQL_DATABASE_URL=mysql://analysis:analysis@127.0.0.1:3306/mugplan_analysis knip --config knip.config.ts --files --reporter compact --no-progress --no-exit-code",
    "analyze:all": "npm run analyze:arch && npm run analyze:boundaries && npm run analyze:coverage && npm run analyze:knip",
    "audit": "npm audit --audit-level=moderate",
    "secrets": "powershell -NoProfile -ExecutionPolicy Bypass -File script/run-gitleaks.ps1 detect --source . --no-git",
    "review": "npm run typecheck && npm run lint && npm run audit && npm run secrets",
    "check:encoding": "tsx script/check-frontend-encoding.ts",
    "check:encoding:frontend": "npm run check:encoding",
    "lint:encoding": "node scripts/check-encoding.mjs",
    "check:destructive-inventory": "tsx script/check-destructive-inventory.ts",
    "db:push": "drizzle-kit push",
    "db:migration-status:dev": "cross-env NODE_ENV=development tsx script/check-migration-status.ts",
    "db:migration-status:test": "cross-env NODE_ENV=test MUGPLAN_MODE=test tsx script/check-migration-status.ts",
    "db:migration-status:prod": "cross-env NODE_ENV=production node --env-file=.env.prod ./node_modules/tsx/dist/cli.mjs script/check-migration-status.ts",
    "db:migrate:dev": "cross-env NODE_ENV=development tsx script/run-migrations.ts",
    "db:migrate:test": "cross-env NODE_ENV=test MUGPLAN_MODE=test tsx script/run-migrations.ts",
    "db:migrate:prod": "cross-env NODE_ENV=production node --env-file=.env.prod ./node_modules/tsx/dist/cli.mjs script/run-migrations.ts",
    "db:migrate:project-names": "tsx script/migrate-project-names-with-customer-number.ts",
    "db:seed:roles": "tsx script/seed-roles.ts",
    "test:template-render": "tsx script/test-template-render.ts",
    "test": "cross-env NODE_ENV=test MUGPLAN_MODE=test vitest",
    "test:run": "cross-env NODE_ENV=test MUGPLAN_MODE=test vitest run",
    "test:extraction:mock": "cross-env NODE_ENV=test MUGPLAN_MODE=test vitest run tests/integration/server/documentExtraction.routes.test.ts tests/unit/validation/extractionValidator.structure.test.ts tests/unit/services/documentProcessing.customerResolution.test.ts tests/unit/ui/projectForm.documentExtractionFlow.test.tsx tests/unit/ui/appointmentForm.documentExtractionFlow.test.tsx tests/unit/extraction/documentTextExtractor.test.ts tests/unit/validation/dtoValidators.test.ts",
    "test:extraction": "npm run test:extraction:mock",
    "test:unit": "cross-env NODE_ENV=test MUGPLAN_MODE=test vitest run --config vitest.workspace.ts --project unit",
    "test:integration": "cross-env NODE_ENV=test MUGPLAN_MODE=test vitest run --config vitest.workspace.ts --project integration",
    "test:e2e": "cross-env NODE_ENV=test MUGPLAN_MODE=test vitest run --config vitest.workspace.ts --project e2e",
    "test:e2e:browser": "cross-env NODE_ENV=test MUGPLAN_MODE=test playwright test -c playwright.config.ts",
    "test:load:ft04": "cross-env NODE_ENV=test MUGPLAN_MODE=test tsx script/ft04-load-test.ts",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:e2e && npm run test:e2e:browser",
    "test:coverage": "cross-env NODE_ENV=test MUGPLAN_MODE=test vitest run --coverage"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "@hookform/resolvers": "^3.10.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@radix-ui/react-accordion": "^1.2.4",
    "@radix-ui/react-alert-dialog": "^1.1.7",
    "@radix-ui/react-aspect-ratio": "^1.1.3",
    "@radix-ui/react-avatar": "^1.1.4",
    "@radix-ui/react-checkbox": "^1.1.5",
    "@radix-ui/react-collapsible": "^1.1.4",
    "@radix-ui/react-context-menu": "^2.2.7",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-dropdown-menu": "^2.1.7",
    "@radix-ui/react-hover-card": "^1.1.7",
    "@radix-ui/react-label": "^2.1.3",
    "@radix-ui/react-menubar": "^1.1.7",
    "@radix-ui/react-navigation-menu": "^1.2.6",
    "@radix-ui/react-popover": "^1.1.7",
    "@radix-ui/react-progress": "^1.1.3",
    "@radix-ui/react-radio-group": "^1.2.4",
    "@radix-ui/react-scroll-area": "^1.2.4",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-separator": "^1.1.3",
    "@radix-ui/react-slider": "^1.2.4",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.1.4",
    "@radix-ui/react-tabs": "^1.1.4",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.3",
    "@radix-ui/react-toggle-group": "^1.1.3",
    "@radix-ui/react-tooltip": "^1.2.0",
    "@tanstack/react-query": "^5.60.5",
    "@types/leaflet": "^1.9.21",
    "archiver": "^7.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "connect-pg-simple": "^10.0.0",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.7.0",
    "exceljs": "^4.4.0",
    "express": "^5.0.1",
    "express-session": "^1.18.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.453.0",
    "memorystore": "^1.6.7",
    "nanoid": "^3.3.11",
    "node-cron": "^4.2.1",
    "otplib": "^13.3.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pdfjs-dist": "^4.10.38",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.55.0",
    "react-leaflet": "^4.2.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.2.5",
    "unzipper": "^0.12.3",
    "wouter": "^3.3.5",
    "yaml": "^2.8.3",
    "zod": "^3.24.2",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@replit/vite-plugin-cartographer": "^0.4.4",
    "@replit/vite-plugin-dev-banner": "^0.1.1",
    "@replit/vite-plugin-runtime-error-modal": "^0.0.3",
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/react": "^16.3.2",
    "@types/archiver": "^7.0.0",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "20.19.27",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/pdfkit": "^0.17.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.3",
    "@types/unzipper": "^0.10.11",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^4.1.1",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "dependency-cruiser": "^17.3.10",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.8",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.2",
    "eslint-plugin-boundaries": "^6.0.2",
    "knip": "^6.4.1",
    "mysql2": "^3.17.1",
    "postcss": "^8.5.10",
    "selfsigned": "^5.5.0",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "5.6.3",
    "vite": "^7.3.1",
    "vitest": "^4.1.1"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "drizzle-kit": {
      "@esbuild-kit/esm-loader": "npm:tsx@^4.20.4"
    }
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  }
}
