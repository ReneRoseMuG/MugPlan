# ============================================================
# Environment example (copy and rename per mode)
# Local dev:   .env.dev
# Local test:  .env.test
# Server prod: .env.prod (e.g. in ../../shared/.env.prod)
# ============================================================

# Core database connection used by the current runtime process
# Format: mysql://user:password@host:3306/database_name
MYSQL_DATABASE_URL=mysql://user:password@localhost:3306/provider_db_name_dev

# Runtime logging
LOG_LEVEL=INFO
LOG_SQL=false
LOG_HTTP_MODE=errors
LOG_HTTP_SLOW_MS=1000

# Session / auth
SESSION_SECRET=change-me
AUTH_QUICK_LOGIN_ENABLED=true
VITE_AUTH_QUICK_LOGIN_ENABLED=true

# Storage paths (adjust per environment)
ATTACHMENT_STORAGE_PATH=C:/path/to/uploads
BACKUP_BASE_PATH=C:/path/to/backups

# ============================================================
# DB safety guards (explicit allowlists, no suffix assumptions)
# ============================================================
# Comma-separated database names (exact names as seen in URL path / SELECT DATABASE()).
# Only the list matching the active NODE_ENV is used by the guards.
DB_ALLOWED_DATABASES_DEV=provider_db_name_dev
DB_ALLOWED_DATABASES_TEST=provider_db_name_test
DB_ALLOWED_DATABASES_PROD=provider_db_name_prod

# Optional host allowlists (comma-separated).
# Leave empty to disable host check for that mode.
# Use exact host names as parsed from MYSQL_DATABASE_URL.
DB_ALLOWED_HOSTS_DEV=localhost
DB_ALLOWED_HOSTS_TEST=localhost
DB_ALLOWED_HOSTS_PROD=

# ============================================================
# Notes
# ============================================================
# NODE_ENV is usually set by npm scripts:
# - development via `npm run dev`
# - test via `npm test`
# - production via `npm start`
#
# Create separate real files with mode-specific MYSQL_DATABASE_URL:
# - .env.dev  -> dev DB
# - .env.test -> test DB
# - .env.prod -> prod DB
#
# Example (provider random names are fine):
#   Dev:  MYSQL_DATABASE_URL=mysql://.../dbu_rvtagh
#   Test: MYSQL_DATABASE_URL=mysql://.../dbu_ab12cd
#   Prod: MYSQL_DATABASE_URL=mysql://.../dbu_x9k2lm
#
# Then set matching allowlists, e.g.:
#   DB_ALLOWED_DATABASES_DEV=dbu_rvtagh
#   DB_ALLOWED_DATABASES_TEST=dbu_ab12cd
#   DB_ALLOWED_DATABASES_PROD=dbu_x9k2lm