# ============================================================
# Explicit env model (no fallback files)
# Fixed file names:
#   development -> .env.dev
#   test        -> .env.test
#   production  -> .env.prod (loaded by npm start via --env-file)
# Hard operating rule:
#   Start app/test from the project root so relative paths are correct.
# ============================================================

# Core database connection
MYSQL_DATABASE_URL=mysql://user:password@localhost:3306/provider_db_name_dev

# Runtime logging
LOG_LEVEL=INFO
LOG_SQL=false
LOG_HTTP_MODE=errors
LOG_HTTP_SLOW_MS=1000

# Session / auth
SESSION_SECRET=change-me
# Session cookie security mode:
# - auto  : use secure cookie when request is detected as HTTPS (recommended for production behind proxy)
# - true  : always secure cookie
# - false : never secure cookie
SESSION_COOKIE_SECURE=auto
# Express trust proxy setting:
# - 1     : trust first proxy hop (default in production when unset)
# - true  : trust all proxy hops
# - false : disable proxy trust (default in development/test when unset)
TRUST_PROXY=1
AUTH_QUICK_LOGIN_ENABLED=true
VITE_AUTH_QUICK_LOGIN_ENABLED=true

# Storage paths
# Relative values are resolved against process.cwd() (project root at startup)
ATTACHMENT_STORAGE_PATH=./uploads
BACKUP_BASE_PATH=./backups

# ============================================================
# Mandatory DB/Host allowlists for the active mode
# CSV format, exact values, no empty lists
# ============================================================
DB_ALLOWED_DATABASES_DEV=provider_db_name_dev
DB_ALLOWED_DATABASES_TEST=provider_db_name_test
DB_ALLOWED_DATABASES_PROD=provider_db_name_prod

DB_ALLOWED_HOSTS_DEV=localhost
DB_ALLOWED_HOSTS_TEST=localhost
DB_ALLOWED_HOSTS_PROD=db-prod.example.com
